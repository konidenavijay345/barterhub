rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow read/write to analytics events (write-only for public, read only for server)
    match /analytics_events/{doc} {
      allow create: if true;
      allow read: if false; // Only read via admin SDK or Firebase Console
    }

    // Sessions — only owner can read/delete
    match /sessions/{token} {
      allow read, write, delete: if true; // Auth is handled at app level
    }

    // Users — read all, write own only
    match /users/{userId} {
      allow read: if true;
      allow write: if true; // Tighten later with auth
    }

    // Listings — public read, authenticated write
    match /listings/{listingId} {
      allow read: if true;
      allow write: if true;
    }

    // Exchanges — public read, write
    match /exchanges/{exchangeId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
